{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["tasks"],
  "properties": {
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "taskStatus": { "type": "string", "enum": ["draft", "published", "deprecated"] },
    "path": { "type": "string", "pattern": "^/[-a-zA-Z0-9/_]*$", "minLength": 1 },
    "category": { "type": "string", "minLength": 2, "maxLength": 64, "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "status", "path"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$" },
        "title": { "type": "string", "minLength": 3 },
        "description": { "type": "string", "minLength": 10, "maxLength": 300 },
        "category": { "$ref": "#/$defs/category" },
        "status": { "$ref": "#/$defs/taskStatus" },
        "deprecated_redirect": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/path" }] },
        "last_verified": { "type": "string", "format": "date" },
        "synonyms": { "type": "array", "items": { "type": "string", "minLength": 2 }, "uniqueItems": true, "default": [] },
        "path": { "$ref": "#/$defs/path" },
        "roles": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "pitfalls": { "type": "array", "items": { "type": "object", "required": ["trigger", "resolution"], "properties": { "trigger": { "type": "string" }, "resolution": { "type": "string" } } }, "default": [] },
        "related": { "type": "array", "items": { "$ref": "#/$defs/path" }, "uniqueItems": true, "default": [] }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "deprecated" } } },
          "then": {
            "required": ["deprecated_redirect"],
            "properties": {
              "deprecated_redirect": { "$ref": "#/$defs/path" }
            }
          }
        }
      ]
    }
  }
}
